# ─── API ───────────────────────────────────────────────────────────────────────
# The environment the app runs in (e.g., development, production)
NODE_ENV=development
# The port the API listens on
API_PORT=3001
# The prefix for all API routes
API_PREFIX=api

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Format: postgresql://[user]:[password]@[host]:[port]/[db]
DATABASE_URL=postgresql://postgres:password@localhost:5432/savitools

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string. Format: redis://[host]:[port]
REDIS_URL=redis://localhost:6379

# ─── Stellar ───────────────────────────────────────────────────────────────────
# Stellar network to use (testnet or public)
STELLAR_NETWORK=testnet
# Horizon API URL. Get from Stellar docs or run your own.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Soroban RPC URL. Get from Stellar docs.
STELLAR_RPC_URL=https://soroban-rpc-testnet.stellar.org
# Stellar network passphrase. Matches the STELLAR_NETWORK.
STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# ─── Contracts / Deployer ─────────────────────────────────────────────────────
# Secret key used to deploy contracts. Needs to be funded on the target network.
DEPLOYER_SECRET_KEY=SAVPVY3XQFVM6OQCJY6736KO3J4UOTNIX2I2HZG5GHJZ5O3LKV2O7XYZ

# ─── Webhooks ──────────────────────────────────────────────────────────────────
# Secret used to sign webhook payloads. Generate a random string.
WEBHOOK_SIGNING_SECRET=your-signing-secret-here

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Secret used for JWT token generation. Generate a long random string.
JWT_SECRET=change-me-in-production-use-a-long-random-string
# The origin of the web frontend, used for CORS
WEB_ORIGIN=http://localhost:3000

# Fluxa SSO — optional in development (mock tenant IDs are used when unset). URL of Fluxa API.
FLUXA_API_URL=https://api.fluxa.io

# ─── Playground ─────────────────────────────────────────────────────────────────
# API URL for CrowdPay services
CROWDPAY_API_URL=https://api.crowdpay.io
# Time-to-live for playground specs in milliseconds (e.g., 3600000 for 1 hour)
PLAYGROUND_SPEC_TTL_MS=3600000
